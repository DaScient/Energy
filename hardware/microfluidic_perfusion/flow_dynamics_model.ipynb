# Cell 1: Setup and Constants
import numpy as np
import matplotlib.pyplot as plt

# Tissue parameters
organoid_radius_um = 1500  # 1.5mm radius
diffusion_coeff_o2 = 2.0e-5 # cm^2/s
consumption_rate = 1.5e-4 # mol/cm^3/s

# Cell 2: Simulating the Gradient
def simulate_oxygen_gradient(radius_um, d_coeff, c_rate):
    """
    Calculates the steady-state oxygen concentration profile 
    from the perfused surface to the organoid core.
    """
    r = np.linspace(0, radius_um, 100)
    # Simplified spherical diffusion equation analytical solution
    # C(r) = C_surface - (c_rate / (6 * d_coeff)) * (R^2 - r^2)
    c_surface = 0.21 # Ambient O2 
    c_r = c_surface - (c_rate / (6 * d_coeff)) * ((radius_um/10000)**2 - (r/10000)**2)
    return r, np.maximum(c_r, 0) # Oxygen cannot drop below 0

radii, o2_profile = simulate_oxygen_gradient(organoid_radius_um, diffusion_coeff_o2, consumption_rate)

# Cell 3: Visualization
plt.plot(radii, o2_profile, color='teal', linewidth=2)
plt.axhspan(0, 0.05, color='red', alpha=0.3, label='Necrotic Risk Zone')
plt.title('Oxygen Diffusion Gradient in Brain Organoid')
plt.xlabel('Distance from Core ($\mu m$)')
plt.ylabel('Oxygen Concentration')
plt.legend()
plt.show()
