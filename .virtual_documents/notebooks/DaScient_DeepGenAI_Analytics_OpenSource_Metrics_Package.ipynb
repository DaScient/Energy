def composite_score(metrics: Dict[str, float], weights: Dict[str, float]) -> float:
    total = 0.0
    for k, w in weights.items():
        if k not in metrics:
            continue
        v = metrics[k]
        if v is None or (isinstance(v, float) and (math.isnan(v) or math.isinf(v))):
            continue
        total += w * float(v)
    return float(total)

