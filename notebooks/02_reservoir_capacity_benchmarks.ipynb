# Cell 1: Setup and Signal Processing Dependencies
import numpy as np
from sklearn.linear_model import Ridge
from sklearn.metrics import mean_squared_error
import matplotlib.pyplot as plt

print("Initializing Biological Reservoir Benchmarking Suite...")

# Cell 2: Fading Memory Capacity Calculation
def calculate_memory_capacity(input_signal, reservoir_states, max_delay=20):
    """
    Measures how well the readout layer can reconstruct past inputs 
    from the current high-dimensional biological state space.
    """
    memory_scores = []
    
    for delay in range(1, max_delay + 1):
        # Shift the target signal backward in time
        target = input_signal[:-delay]
        features = reservoir_states[delay:]
        
        # Train a simple linear readout
        readout = Ridge(alpha=1e-3)
        readout.fit(features, target)
        predictions = readout.predict(features)
        
        # Calculate correlation squared (memory capacity for this delay)
        r_squared = np.corrcoef(target, predictions)[0, 1]**2
        memory_scores.append(r_squared)
        
    total_capacity = sum(memory_scores)
    return memory_scores, total_capacity

# Cell 3: Simulating Organoid Reservoir Responses
# In production, this data comes from the MEA or Optogenetic arrays
time_steps = 1000
num_channels = 256 # MEA channel count

# Generate a random temporal input sequence
u_t = np.random.uniform(-1, 1, time_steps)

# Simulate the nonlinear, fading-memory response of the organoid
x_t = np.zeros((time_steps, num_channels))
for t in range(1, time_steps):
    # x(t) = tanh(W_res * x(t-1) + W_in * u(t)) -> Simulated biological dynamics
    decay = 0.8
    innovation = np.random.normal(0, 0.1, num_channels) * u_t[t]
    x_t[t] = decay * x_t[t-1] + np.tanh(innovation)

# Cell 4: State Richness and Separability Evaluation
def evaluate_separability(states_class_a, states_class_b):
    """
    Measures the Euclidean distance between state trajectories 
    driven by two distinct input classes (e.g., varying pulse trains).
    """
    centroid_a = np.mean(states_class_a, axis=0)
    centroid_b = np.mean(states_class_b, axis=0)
    distance = np.linalg.norm(centroid_a - centroid_b)
    return distance

# Cell 5: Report Generation
memory_profile, total_mc = calculate_memory_capacity(u_t, x_t)

plt.figure(figsize=(8, 5))
plt.bar(range(1, 21), memory_profile, color='darkcyan')
plt.title("Fading Memory Profile of Biological Reservoir")
plt.xlabel("Time Delay ($\tau$)")
plt.ylabel("Reconstruction Accuracy ($R^2$)")
plt.show()

print(f"Total Memory Capacity (MC): {total_mc:.2f}")
print("State Richness (Variance):", np.var(x_t))
