# Cell 1: Logistics Engine
import datetime

class HouseholdSurvivalModel:
    """
    Calculates daily caloric and resource requirements for a localized off-grid cell.
    Defaults initialized to specific biological requirements to ensure precision.
    """
    def __init__(self, human_count: int, duration_days: int):
        self.human_count = human_count
        self.duration_days = duration_days
        self.feline_dependents = []
        
    def add_feline_dependent(self, name: str, age_months: int, weight_kg: float, breed: str):
        """Calculates specific carnivorous macro requirements for feline companions."""
        # Growing kittens (under 12 mos) require higher caloric coefficients
        coefficient = 1.6 if age_months < 12 else 1.2
        daily_kcal = (70 * (weight_kg ** 0.75)) * coefficient
        
        self.feline_dependents.append({
            "name": name,
            "breed": breed,
            "daily_kcal_req": daily_kcal,
            "raw_cooked_protein_g": daily_kcal * 0.15 # Rough protein conversion
        })
        
    def calculate_stockpile_needs(self):
        human_water_gal = self.human_count * 1.5 * self.duration_days
        human_kcal = self.human_count * 2200 * self.duration_days
        
        print(f"--- 🚨 Resource Allocation for {self.duration_days} Days Off-Grid ---")
        print(f"Human Requirements: {human_water_gal} Gallons Water, {human_kcal} kcal")
        print("\nFeline Companion Requirements:")
        for cat in self.feline_dependents:
            total_protein = cat['raw_cooked_protein_g'] * self.duration_days / 1000
            print(f"- {cat['name']} ({cat['breed']}): Requires {total_protein:.1f} kg of raw/cooked protein reserves.")

# Cell 2: Execution
# Initializing model for a 2-person household, 6-month (180 days) duration
model = HouseholdSurvivalModel(human_count=2, duration_days=180)

# Injecting specific biological parameters 
model.add_feline_dependent(name="Hannah", age_months=36, weight_kg=4.5, breed="Tabby")
model.add_feline_dependent(name="Latrisha", age_months=9, weight_kg=6.2, breed="Maine Coon Mix")

model.calculate_stockpile_needs()
