# Cell 1: Bio-Telemetry Setup
import numpy as np
import scipy.signal as signal
import matplotlib.pyplot as plt

print("Initializing Neural Telemetry & Bio-Monitor Parsing...")

# Cell 2: Processing HRV and EEG Data
def analyze_operator_fatigue(hrv_array, eeg_alpha_beta_ratio):
    """
    Evaluates operator resilience by correlating Heart Rate Variability (HRV)
    with EEG frequency bands to detect cognitive burnout before failure.
    """
    # HRV below 35ms in a high-stress scenario indicates sympathetic nervous overload
    sympathetic_overload = np.where(hrv_array < 35, True, False)
    
    # An elevated Alpha/Beta ratio indicates decreasing alertness/focus
    cognitive_fatigue = np.where(eeg_alpha_beta_ratio > 1.5, True, False)
    
    critical_failure_risk = np.logical_and(sympathetic_overload, cognitive_fatigue)
    return critical_failure_risk

# Cell 3: Simulating 72-Hour Operator Telemetry
hours = np.linspace(0, 72, 720) # 72 hours, sampled every 6 mins
simulated_hrv = 60 - (hours * 0.4) + np.random.normal(0, 5, len(hours))
simulated_eeg_ratio = 0.8 + (hours * 0.015) + np.random.normal(0, 0.1, len(hours))

# Run Analysis
risk_flags = analyze_operator_fatigue(simulated_hrv, simulated_eeg_ratio)
failure_points = hours[risk_flags]

# Cell 4: Visualization
plt.figure(figsize=(10, 5))
plt.plot(hours, simulated_hrv, color='blue', alpha=0.6, label='HRV (ms)')
plt.axhline(35, color='red', linestyle='--', label='Sympathetic Overload Threshold')
if len(failure_points) > 0:
    plt.scatter(failure_points, [35]*len(failure_points), color='darkred', marker='x', label='Critical Fatigue Imminent')

plt.title('Operator Biometric Telemetry During 72-Hr Simulation')
plt.xlabel('Mission Time (Hours)')
plt.ylabel('Heart Rate Variability (ms)')
plt.legend()
plt.tight_layout()
plt.show()

if len(failure_points) > 0:
    print(f"WARNING: Operator cognitive failure predicted at T+{failure_points[0]:.1f} hours.")
    print("Action Required: Force sleep cycle or route cognitive load to Quantum/Biological co-processors.")
